# ============================================
# ChatGPT2API 环境变量配置示例
# ============================================

# 初始管理员账号；未设置密码时首次启动会生成一次性密码并输出到日志
CHATGPT2API_ADMIN_USERNAME=admin
# CHATGPT2API_ADMIN_PASSWORD=change_me_please

# 是否开放登录页账号注册入口
CHATGPT2API_REGISTRATION_ENABLED=false

# 基础 URL（可选，用于生成图片 URL）
# CHATGPT2API_BASE_URL=https://your-domain.com

# 全局代理（可选，支持 http/https/socks5/socks5h）
# CHATGPT2API_PROXY=http://127.0.0.1:7890

# 检查更新访问 DockerHub / Release API 的代理；未设置时复用 CHATGPT2API_PROXY
# CHATGPT2API_UPDATE_PROXY_URL=http://127.0.0.1:7890

# ============================================
# 服务器源码 Docker 构建资源控制（仅 sh deploy/docker-build-limited.sh 使用）
# ============================================

# 需要在服务器从源码构建镜像时，推荐用脚本创建受限 BuildKit builder 后再构建。
# 直接运行脚本时会按服务器资源自动选择默认值，资源充足时默认使用 2 核和更高内存。
# 如需手动覆盖，可取消下面注释。
# BUILD_CPUS=2
# BUILD_MEMORY=4g
# BUILD_MEMORY_SWAP=4g
# BUILDKIT_MAX_PARALLELISM=2
# BUILD_GOMAXPROCS=2
# BUILD_GOMEMLIMIT=2GiB
# BUILD_NODE_OPTIONS=--max-old-space-size=1024
# CHATGPT2API_LOCAL_IMAGE=chatgpt2api:local

# 限流账号检查间隔，单位：分钟
CHATGPT2API_REFRESH_ACCOUNT_INTERVAL_MINUTE=5

# 图片任务超时时间，单位：秒
CHATGPT2API_IMAGE_TASK_TIMEOUT_SECONDS=300

# 普通用户默认创作并发额度，图片生成/编辑按请求张数计入，聊天任务按 1 个计入；0 表示不限制
CHATGPT2API_USER_DEFAULT_CONCURRENT_LIMIT=0

# 普通用户默认创作任务 RPM 限制，0 表示不限制
CHATGPT2API_USER_DEFAULT_RPM_LIMIT=0

# 服务端缓存图片保留天数
CHATGPT2API_IMAGE_RETENTION_DAYS=30

# 图片库总容量上限，单位 MB；0 表示不按容量自动清理
CHATGPT2API_IMAGE_STORAGE_LIMIT_MB=0

# 业务日志保留天数；设置页的日志数据治理会按该值清理历史日志
CHATGPT2API_LOG_RETENTION_DAYS=7

# 自动移除失效账号
CHATGPT2API_AUTO_REMOVE_INVALID_ACCOUNTS=true

# 自动移除限流账号
CHATGPT2API_AUTO_REMOVE_RATE_LIMITED_ACCOUNTS=false

# 记录日志级别，多个值用英文逗号分隔：debug,info,warning,error
# CHATGPT2API_LOG_LEVELS=warning,error

# ============================================
# Linuxdo 登录配置（可选）
# ============================================

# 启用 Linuxdo Connect 登录
# CHATGPT2API_LINUXDO_ENABLED=false

# Linuxdo Connect 应用凭据
# CHATGPT2API_LINUXDO_CLIENT_ID=
# CHATGPT2API_LINUXDO_CLIENT_SECRET=

# 后端 OAuth 回调地址；Linuxdo Connect 应用后台也必须填写这个后端地址。
# 如未设置且 CHATGPT2API_BASE_URL 已设置，会默认使用：
# ${CHATGPT2API_BASE_URL}/auth/linuxdo/oauth/callback
# CHATGPT2API_LINUXDO_REDIRECT_URL=https://your-domain.com/auth/linuxdo/oauth/callback

# 前端接收本地会话密钥的路由；不要填到 Linuxdo Connect 应用后台。
# CHATGPT2API_LINUXDO_FRONTEND_REDIRECT_URL=/auth/linuxdo/callback

# Linuxdo Connect 端点，通常无需修改
# CHATGPT2API_LINUXDO_AUTHORIZE_URL=https://connect.linux.do/oauth2/authorize
# CHATGPT2API_LINUXDO_TOKEN_URL=https://connect.linux.do/oauth2/token
# CHATGPT2API_LINUXDO_USERINFO_URL=https://connect.linux.do/api/user
# CHATGPT2API_LINUXDO_SCOPES=user

# ============================================
# 存储后端配置
# ============================================

# ============================================
# 图片存储模式
# ============================================

# 图片存储位置：local（仅本地磁盘）或 cloud（上传至云存储，本地副本临时保留）
# 默认: local
# CHATGPT2API_STORAGE_MODE=local

# 云存储上传线路（仅在 storage_mode=cloud 时生效）：a1, a4, s3, auto
# CHATGPT2API_CLOUD_STORAGE_UPLOADER=auto

# A4 上传线路 Cookie（可选）
# CHATGPT2API_A4_COOKIE=

# Cookie 活跃性检查间隔（分钟），默认 240
# CHATGPT2API_CLOUD_COOKIE_CHECK_INTERVAL=240

# 云存储专用代理（可选，隔离云存储流量，不走全局代理）
# 留空则使用全局代理 CHATGPT2API_PROXY
# CHATGPT2API_CLOUD_PROXY=

# ============================================
# S3 兼容云存储配置（仅在 cloud_storage_uploader=s3 时生效）
# 支持 Cloudflare R2、Backblaze B2、MinIO、AWS S3 等
# ============================================

# S3 服务端点
# Cloudflare R2: https://<account_id>.r2.cloudflarestorage.com
# Backblaze B2:  https://s3.us-west-002.backblazeb2.com
# MinIO:         http://localhost:9000
# AWS S3:        https://s3.<region>.amazonaws.com
# CHATGPT2API_S3_ENDPOINT=

# S3 区域（Cloudflare R2 使用 "auto"）
# CHATGPT2API_S3_REGION=auto

# S3 访问密钥
# CHATGPT2API_S3_ACCESS_KEY_ID=
# CHATGPT2API_S3_SECRET_ACCESS_KEY=

# S3 存储桶名称
# CHATGPT2API_S3_BUCKET=

# 自定义公开访问域名（可选，如配置了 Cloudflare Workers 或自定义域名）
# 未设置时使用 S3 端点拼接桶名作为访问地址
# CHATGPT2API_S3_PUBLIC_URL=

# 对象键前缀（可选，用于隔离不同实例的文件）
# CHATGPT2API_S3_PATH_PREFIX=

# 是否使用路径风格（MinIO 需要设为 true；R2/B2/AWS 使用默认 false）
# CHATGPT2API_S3_FORCE_PATH_STYLE=false

# 存储后端类型（可选值: sqlite, postgres, mysql）
# 默认: sqlite
STORAGE_BACKEND=sqlite

# ============================================
# 数据库配置
# ============================================

# PostgreSQL 示例
# DATABASE_URL=postgresql://user:password@localhost:5432/chatgpt2api

# Supabase 示例
# DATABASE_URL=postgresql://postgres.xxx:password@aws-1-us-west-1.pooler.supabase.com:5432/postgres

# SQLite 示例（容器内绝对路径需要四个斜杠；不指定时自动使用 data/chatgpt2api.db）
# DATABASE_URL=sqlite:////app/data/chatgpt2api.db
